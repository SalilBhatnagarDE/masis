# =============================================================================
# MASIS — Multi-Agent Supervised Intelligence System
# Environment Variables Template
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp masis/.env.example masis/.env
#
# Required variables are marked [REQUIRED].
# Optional variables are marked [OPTIONAL] with their default shown.
#
# NEVER commit your .env file to version control.
# The .gitignore should already exclude .env files.
# =============================================================================


# =============================================================================
# OPENAI  [REQUIRED]
# =============================================================================
# All LLM calls (Supervisor, Researcher, Skeptic, Synthesizer) use the OpenAI API.
# Format: sk-proj-... or sk-...
OPENAI_API_KEY=sk-proj-your-openai-api-key-here


# =============================================================================
# DATABASE — PostgreSQL for LangGraph checkpointing  [OPTIONAL in dev, REQUIRED in prod]
# =============================================================================
# Used by PostgresSaver for fault-tolerant state persistence and HITL resume.
# In development, InMemorySaver is used automatically when this is not set.
#
# Docker dev setup:
#   docker run -d --name masis-postgres \
#     -e POSTGRES_USER=masis \
#     -e POSTGRES_PASSWORD=masis_dev_2026 \
#     -e POSTGRES_DB=masis_checkpoints \
#     -p 5432:5432 postgres:16
#
POSTGRES_URL=postgresql://masis:masis_dev_2026@localhost:5432/masis_checkpoints


# =============================================================================
# WEB SEARCH — Tavily API  [OPTIONAL — required for web_search tasks]
# =============================================================================
# Used by the WebSearch agent (task type: "web_search") for external research.
# If not set, web_search tasks will return an error and Supervisor routes around them.
# Register at: https://tavily.com
TAVILY_API_KEY=tvly-your-tavily-api-key-here


# =============================================================================
# OBSERVABILITY — Langfuse  [OPTIONAL]
# =============================================================================
# Traces every LLM call with inputs/outputs, latency, and cost (MF-API-06).
# Register at: https://langfuse.com
# If not set, tracing is disabled (system still works normally).
LANGFUSE_SECRET_KEY=sk-lf-your-langfuse-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-langfuse-public-key
LANGFUSE_HOST=https://cloud.langfuse.com


# =============================================================================
# OBSERVABILITY — LangSmith  [OPTIONAL]
# =============================================================================
# Alternative to Langfuse for LangChain/LangGraph tracing.
# Register at: https://smith.langchain.com
LANGSMITH_API_KEY=lsv2_your-langsmith-api-key
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=masis-production


# =============================================================================
# MODEL ROUTING  [OPTIONAL — defaults shown]
# =============================================================================
# Override any model assignment without changing code.
# See config/model_routing.py for the full routing table and trade-off notes.
#
# Supervisor: gpt-4.1 recommended (strategic DAG planning)
# WARNING: Changing the supervisor model can degrade DAG quality significantly.
MODEL_SUPERVISOR=gpt-4.1

# Researcher: gpt-4.1-mini is cost-effective and quality is sufficient for retrieval
# SAFE to swap: MODEL_RESEARCHER=gpt-4.1-nano reduces cost but increases CRAG retries
MODEL_RESEARCHER=gpt-4.1-mini

# Skeptic LLM judge: o3-mini is different model family from Synthesizer (anti-sycophancy)
# CAREFUL: cheaper models may miss contradictions
MODEL_SKEPTIC=o3-mini

# Synthesizer: gpt-4.1 for user-facing answer quality
# NOT recommended to swap — user-facing quality degrades
MODEL_SYNTHESIZER=gpt-4.1

# Ambiguity Detector: gpt-4.1-mini is sufficient for query classification
MODEL_AMBIGUITY=gpt-4.1-mini

# Embedding model for vector search (ChromaDB)
MODEL_EMBEDDER=text-embedding-3-small


# =============================================================================
# AGENT RATE LIMITS  [OPTIONAL — defaults shown]
# =============================================================================
# Overrides for per-agent concurrency and timeout limits (MF-SAFE-05).
# These protect against API rate limits and runaway parallel execution.

RESEARCHER_MAX_PARALLEL=3
RESEARCHER_MAX_TOTAL=8
RESEARCHER_TIMEOUT_S=30

WEB_SEARCH_MAX_PARALLEL=2
WEB_SEARCH_MAX_TOTAL=4
WEB_SEARCH_TIMEOUT_S=15

SKEPTIC_MAX_PARALLEL=1
SKEPTIC_MAX_TOTAL=3
SKEPTIC_TIMEOUT_S=45

SYNTHESIZER_MAX_PARALLEL=1
SYNTHESIZER_MAX_TOTAL=3
SYNTHESIZER_TIMEOUT_S=60


# =============================================================================
# INFRASTRUCTURE  [OPTIONAL — defaults shown]
# =============================================================================
# ChromaDB vector store persistence directory.
# Use an absolute path in production (e.g. /data/masis/chroma_db).
CHROMA_PERSIST_DIRECTORY=./chroma_db

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Deployment environment affects validation strictness and PostgreSQL requirement.
# Values: development | staging | production
ENVIRONMENT=development
