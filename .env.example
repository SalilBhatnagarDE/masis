# =============================================================================
# MASIS Environment Variables Template (Root)
# =============================================================================
# Single source of truth for local configuration.
# Copy to `.env` and fill in values locally.
#
#   cp .env.example .env
#
# Never commit `.env` with real credentials.

# Required
OPENAI_API_KEY=<your_openai_api_key>

# Optional integrations
TAVILY_API_KEY=<your_tavily_api_key_optional>
LLAMA_CLOUD_API_KEY=<your_llama_cloud_api_key_optional>
CHROMA_OPENAI_API_KEY=<optional_openai_key_for_chroma_fallback>

# Runtime environment
ENVIRONMENT=development
LOG_LEVEL=INFO
QUERY_TIMEOUT_SECONDS=300

# Model routing
MODEL_SUPERVISOR=gpt-4.1
MODEL_RESEARCHER=gpt-4.1-mini
MODEL_SKEPTIC=o3-mini
MODEL_SYNTHESIZER=gpt-4.1
MODEL_AMBIGUITY=gpt-4.1-mini
MODEL_EMBEDDER=text-embedding-3-small

# Storage
CHROMA_PERSIST_DIRECTORY=./chroma_db
POSTGRES_URL=

# Observability (optional)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=masis
